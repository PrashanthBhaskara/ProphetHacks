# Copy to prep/.env and fill in keys. These are the EXACT settings used
# to produce the validated Brier numbers in HANDOFF.md. Don't change
# unless you're re-running the backtest.

# ── REQUIRED: API KEYS ──
OPENROUTER_API_KEY=sk-or-v1-REPLACE_ME
PA_SERVER_API_KEY=prophet_REPLACE_ME

# Optional: only needed if you want to call grok-4.3 direct (not used by live_submission.sh)
# XAI_API_KEY=xai-REPLACE_ME

# Optional: only needed for claude_zero_shot baseline (not in the live ensemble)
# ANTHROPIC_API_KEY=sk-ant-REPLACE_ME

# ── EXACT TESTED MODEL SETTINGS ──
# Model: pinned to x-ai/grok-4.20. live_submission.sh exports this for both LLM legs.
OPENROUTER_MODEL=x-ai/grok-4.20

# Temperature for grok_filtered / trust_extreme leg. (websearch leg hardcodes 0.3 in code.)
OPENROUTER_TEMPERATURE=0.7

# Bi-directional prompting: ask P(YES), separately ask P(NO), average. 1=on, 0=off.
OPENROUTER_BIDIR=1

# Web-search leg: number of search results to retrieve per market.
OPENROUTER_WEB_RESULTS=5

# Noise-removal filter thresholds for grok_filtered. Skip Grok and let market speak when:
#   - volume above this OR
#   - mid price ≤ this (extreme low) OR mid ≥ (1 - this) (extreme high) OR
#   - ticker is ATP tennis (hardcoded in grok_filtered.py)
GROK_VOLUME_THRESHOLD=4000
GROK_EXTREME_THRESHOLD=0.15
