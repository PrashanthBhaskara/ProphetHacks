# Local development placeholders only. Never commit real secrets.

# App runtime
PROPHET_CONFIG=prophet-hacks-handoff/prep/config/FINAL.json
ENSEMBLE_TIMEOUT_SECONDS=585
LANE_TIMEOUT_SECONDS=450
GROK_TIMEOUT_SECONDS=450
KALSHI_TIMEOUT_SECONDS=5
KALSHI_MAX_ATTEMPTS=2

# Gemini Pro lane, direct Gemini API for native Google Search grounding.
GEMINI_PRO_API_KEY=
GEMINI_FALLBACK_API_KEY=

# OpenRouter lanes. Each lane has one primary key plus the shared fallback.
DHRUV_OPENROUTER_API_KEY=
CLAUDE_OPENROUTER_API_KEY=
GROK_OPENROUTER_API_KEY=
OPENAI_JUDGE_OPENROUTER_API_KEY=
OPENROUTER_FALLBACK_API_KEY=
OPENROUTER_TIMEOUT_SECONDS=90

# Dhruv lane live retrieval and grounding.
ARENA_ENABLE_LIVE_DATA=1
ARENA_ENABLE_GROUNDED_RESEARCH=1
ARENA_ENABLE_BACKTEST_INTERNET=0
ARENA_LIVE_PIT_EXTERNAL_NETWORK=0
ARENA_RESPONSE_DEADLINE_SECONDS=450
ARENA_LIVE_ACCELERATE_AFTER_SECONDS=360
ARENA_FINAL_FALLBACK_RESERVE_SECONDS=20

# Optional authenticated Kalshi read access. Public market fallback works without these.
KALSHI_BASE_URL=
KALSHI_API_KEY_ID=
KALSHI_PRIVATE_KEY_B64=
KALSHI_PRIVATE_KEY=
KALSHI_PRIVATE_KEY_PATH=

# Optional live data vendor keys used only if available.
FRED_API_KEY=
WRDS_USERNAME=
WRDS_PASSWORD=
WRDS_API_URL=
WRDS_API_KEY=
WRDS_ACCESS_TOKEN=
LSEG_APP_KEY=
LSEG_APP_KEY_EIKON=
LSEG_APP_KEY_SIDE_BY_SIDE=
LSEG_NEWS_API_URL=lseg-data-library://news
EIA_API_KEY=
BEA_API_KEY=
POLYGON_API_KEY=
ODDSPIPE_API_KEY=
