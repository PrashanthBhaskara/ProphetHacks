# Local development placeholders only. Never commit real secrets.

# App runtime. Prep-relative PROPHET_CONFIG is for commands run from prophet-hacks-handoff/prep.
PROPHET_CONFIG=config/FINAL.json
ENSEMBLE_TIMEOUT_SECONDS=585
LANE_TIMEOUT_SECONDS=450
GROK_TIMEOUT_SECONDS=450
KALSHI_TIMEOUT_SECONDS=5
KALSHI_MAX_ATTEMPTS=2

# Lane API keys.
# gemini_pro -> gemini-3-pro-preview via direct Gemini API with Google Search grounding.
GEMINI_PRO_API_KEY=
GEMINI_FALLBACK_API_KEY=

# dhruv_gemini_lane -> google/gemini-3-flash-preview via OpenRouter, one pass, native web search enabled.
DHRUV_OPENROUTER_API_KEY=

# claude_lane -> anthropic/claude-sonnet-4-6 via OpenRouter.
CLAUDE_OPENROUTER_API_KEY=

# grok_lane -> x-ai/grok-4.20 via OpenRouter.
GROK_OPENROUTER_API_KEY=

# Final judge -> openai/gpt-5.4 via OpenRouter.
OPENAI_JUDGE_OPENROUTER_API_KEY=

# Shared fallback for all OpenRouter lanes and the OpenAI judge.
OPENROUTER_FALLBACK_API_KEY=
OPENROUTER_TIMEOUT_SECONDS=90
GEMINI_TIMEOUT_SECONDS=90

# Dhruv lane live retrieval and first-pass native search grounding.
# Keep second pass disabled in config/dhruv_gemini.default.json; Dhruv is one lane, not its own ensemble.
ARENA_ENABLE_GPT=1
ARENA_ENABLE_LIVE_DATA=1
ARENA_ENABLE_GROUNDED_RESEARCH=1
OPENROUTER_NATIVE_SEARCH_GROUNDING=1
OPENROUTER_SEARCH_GROUNDING_ENGINE=native
OPENROUTER_SEARCH_GROUNDING_MAX_RESULTS=5
OPENROUTER_SEARCH_GROUNDING_MAX_TOTAL_RESULTS=8
ARENA_ENABLE_BACKTEST_INTERNET=0
ARENA_LIVE_PIT_EXTERNAL_NETWORK=0
ARENA_RESPONSE_DEADLINE_SECONDS=450
ARENA_TOTAL_EVIDENCE_TIMEOUT_SECONDS=45
ARENA_DEADLINE_RESERVE_SECONDS=30
ARENA_MIN_GPT_CALL_SECONDS=55
ARENA_LIVE_ACCELERATE_AFTER_SECONDS=360
ARENA_FINAL_FALLBACK_RESERVE_SECONDS=20
ARENA_ENABLE_FORECAST_CACHE=1

# Optional authenticated Kalshi read access. Public market fallback works without these.
KALSHI_BASE_URL=
KALSHI_API_KEY_ID=
KALSHI_DEMO_API_KEY_ID=
KALSHI_USE_DEMO=0
KALSHI_PRIVATE_KEY_B64=
KALSHI_PRIVATE_KEY=
KALSHI_PRIVATE_KEY_PATH=

# Optional live data vendor keys used only if available.
FRED_API_KEY=
WRDS_USERNAME=
WRDS_PASSWORD=
WRDS_API_URL=
WRDS_API_KEY=
WRDS_ACCESS_TOKEN=
LSEG_APP_KEY=
LSEG_APP_KEY_EIKON=
LSEG_APP_KEY_SIDE_BY_SIDE=
LSEG_NEWS_API_URL=lseg-data-library://news
EIA_API_KEY=
BEA_API_KEY=
POLYGON_API_KEY=
ODDSPIPE_API_URL=
ODDSPIPE_API_KEY=
