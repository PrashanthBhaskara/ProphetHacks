{
  "model": {
    "name": "arena_probability_model",
    "provider": "gemini",
    "model": "gemini-3-flash-preview",
    "api_key_env": "GEMINI_API_KEY",
    "api_key_fallback_envs": ["GOOGLE_API_KEY"],
    "temperature": 0.1,
    "max_tokens": 1400,
    "enabled": true,
    "search_grounding": {
      "enabled": true,
      "live_only": true,
      "engine": "native",
      "max_results": 5,
      "max_total_results": 8
    }
  },
  "arena": {
    "gpt_enabled_default": true,
    "live_data_enabled_default": true,
    "second_pass_enabled": true,
    "probability_floor": 0.001,
    "probability_ceiling": 0.999,
    "prior_shrink_weight": 0.00,
    "second_pass_delta_pp": 0.12,
    "second_pass_low_confidence": 0.40,
    "second_pass_high_entropy": 0.92,
    "live_cache_ttl_seconds": 900,
    "max_historical_analogs": 8,
    "max_live_evidence": 12,
    "pit_external_enabled_default": false,
    "pit_external_root": "dhruv_GPT_forecasting/data/external_evidence",
    "pit_external_sources": ["local_jsonl", "reddit", "gdelt", "espn", "wrds", "lseg"],
    "pit_external_strict_collected_at": true,
    "pit_external_live_lookback_hours": 24,
    "pit_external_max_records": 12,
    "pit_external_max_live_age_minutes": 10,
    "pit_external_clock_tolerance_seconds": 300,
    "pit_external_archive_live_fetches": true,
    "response_deadline_seconds": 480,
    "evidence_source_timeout_seconds": 5,
    "total_evidence_timeout_seconds": 45,
    "llm_timeout_seconds": 90,
    "deadline_reserve_seconds": 30,
    "min_gpt_call_seconds": 55,
    "live_accelerate_after_seconds": 360,
    "final_fallback_reserve_seconds": 20,
    "grounded_research_enabled_default": true,
    "grounded_research_live_only": true,
    "grounded_research_backtest_enabled": false,
    "grounded_research_timeout_seconds": 45,
    "grounded_research_min_seconds": 20
  },
  "budget": {
    "dry_run_default": true,
    "log_dir": "dhruv_GPT_forecasting/logs",
    "estimated_prices_per_1m_tokens": {
      "openai/gpt-5-nano": {"input": 0.05, "output": 0.40},
      "openai/gpt-5.4": {"input": 5.00, "output": 30.00},
      "openai/gpt-5.5": {"input": 5.00, "output": 30.00},
      "gemini-3-flash-preview": {"input": 0.50, "output": 3.00}
    }
  }
}
