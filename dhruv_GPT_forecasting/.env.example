# Direct Gemini key for the Arena probability model.
GEMINI_API_KEY=
GOOGLE_API_KEY=
GEMINI_TIMEOUT_SECONDS=90
GEMINI_NATIVE_SEARCH_GROUNDING=1

# Optional data/vendor keys used by upstream data collectors.
FRED_API_KEY=
ODDSPIPE_API_KEY=
POLYGON_API_KEY=
EIA_API_KEY=
BEA_API_KEY=
REDDIT_USER_AGENT=ProphetHacksGPTForecasting/0.1

# Optional licensed/normalized vendor connectors.
# For live retrieval, supply a normalized endpoint that accepts q/as_of/limit.
# Native backends are also supported:
#   LSEG_NEWS_API_URL=lseg-data-library://news
#   WRDS_NEWS_API_URL=wrds-postgres://news
# Normalize licensed exports into data/external_evidence/*.jsonl.
WRDS_NEWS_API_URL=wrds-postgres://news
WRDS_API_URL=
WRDS_API_KEY=
WRDS_ACCESS_TOKEN=
WRDS_USERNAME=
WRDS_PASSWORD=
WRDS_API_KEY_HEADER=Authorization
WRDS_NEWS_SQL_FILE=
WRDS_NEWS_SQL=
LSEG_NEWS_API_URL=lseg-data-library://news
LSEG_API_URL=
LSEG_API_KEY=
LSEG_APP_KEY=
LSEG_APP_KEY_EIKON=
LSEG_APP_KEY_SIDE_BY_SIDE=
LSED_APP_KEY_SIDE_BY_SIDE=
LSEG_API_KEY_HEADER=Authorization

# Optional Kalshi/Prophet Arena access.
# The loader accepts KALSHI-ACCESS-KEY and KALSHI-ACCESS-KEY-DEMO aliases
# from prophet-hacks-handoff/prep/.env and maps them internally.
KALSHI_API_KEY_ID=
KALSHI_DEMO_API_KEY_ID=
KALSHI_PRIVATE_KEY_B64=
KALSHI_PRIVATE_KEY_PATH=
KALSHI_USE_DEMO=
PA_SERVER_API_KEY=

# Forecasting-track runtime toggles.
# ARENA_OFFLINE=1 disables GPT and live data for reproducible local tests.
# ARENA_ENABLE_LIVE_DATA=1 enables cached external pulls when relevant keys exist.
# FORECAST_ENABLE_PIT_EXTERNAL=1 enables timestamp-filtered external archives/live pulls.
# PIT_EXTERNAL_ALLOW_NETWORK=1 allows live Reddit/GDELT fetches when as_of is near now.
# PIT_EXTERNAL_ALLOW_HISTORICAL_ARCHIVE_PULLS=1 allows timestamp-bounded GDELT archive pulls ending at as_of.
# PIT_EXTERNAL_ALLOW_REDDIT_BACKFILL_REPLAY=1 allows exploratory replay of Reddit historical backfills.
# ARENA_ENABLE_BACKTEST_INTERNET=1 allows historical grounded internet research only when sources expose
# source-specific published_at/update timestamps at or before the forecast as_of.
ARENA_OFFLINE=
ARENA_ENABLE_GPT=
ARENA_DISABLE_GPT=
ARENA_ENABLE_LIVE_DATA=1
ARENA_DISABLE_LIVE_DATA=
ARENA_LSEG_LLM_QUERY_ENABLED=1
ARENA_LSEG_QUERY_TIMEOUT_SECONDS=12
ARENA_LSEG_QUERY_MIN_SECONDS=4
ARENA_ENABLE_GROUNDED_RESEARCH=1
ARENA_ENABLE_BACKTEST_INTERNET=
ARENA_DISABLE_GROUNDED_RESEARCH=
ARENA_GROUNDED_RESEARCH_TIMEOUT_SECONDS=45
ARENA_GROUNDED_RESEARCH_MIN_SECONDS=20
ARENA_RESPONSE_DEADLINE_SECONDS=480
ARENA_EVIDENCE_SOURCE_TIMEOUT_SECONDS=5
ARENA_TOTAL_EVIDENCE_TIMEOUT_SECONDS=45
ARENA_DEADLINE_RESERVE_SECONDS=30
ARENA_MIN_GPT_CALL_SECONDS=55
ARENA_LIVE_ACCELERATE_AFTER_SECONDS=360
ARENA_FINAL_FALLBACK_RESERVE_SECONDS=20
FORECAST_ENABLE_PIT_EXTERNAL=1
FORECAST_DISABLE_PIT_EXTERNAL=
PIT_EXTERNAL_ALLOW_NETWORK=1
PIT_EXTERNAL_ALLOW_HISTORICAL_ARCHIVE_PULLS=
PIT_EXTERNAL_ALLOW_REDDIT_BACKFILL_REPLAY=
